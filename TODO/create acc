@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun UserCreateAccForm(navController: NavController) {
    var buyerUsername by remember { mutableStateOf("") }
    var buyerEmail by remember { mutableStateOf("") }
    var buyerPass by remember { mutableStateOf("") }
    var buyerConfirmpass by remember { mutableStateOf("") }
    var showUsernameDialog by remember { mutableStateOf(false) }
    var showEmailDialog by remember { mutableStateOf(false) }

    val context = LocalContext.current

    // 🔸 Gradient background (Lazada-like orange tone)
    val gradient = Brush.verticalGradient(
        listOf(
            Color(0xFFFF914D),
            Color(0xFFFF6A00)
        )
    )

    ErrorDialog(
        text = "Username already in use",
        showDialog = showUsernameDialog,
        onDismiss = { showUsernameDialog = false }
    )

    ErrorDialog(
        text = "Email already in use",
        showDialog = showEmailDialog,
        onDismiss = { showEmailDialog = false }
    )

    Scaffold(
        containerColor = Color.Transparent
    ) { innerPadding ->
        Box(
            modifier = Modifier
                .fillMaxSize()
                .background(gradient)
                .padding(innerPadding)
        ) {
            Column(
                modifier = Modifier
                    .fillMaxSize()
                    .verticalScroll(rememberScrollState())
                    .padding(horizontal = 24.dp, vertical = 40.dp),
                horizontalAlignment = Alignment.CenterHorizontally
            ) {
                // Header section
                AppText(
                    text = "Create Account",
                    fontWeight = FontWeight.ExtraBold,
                    fontSize = 30.sp,
                    color = Color.White,
                    textAlign = TextAlign.Center
                )

                Spacer(Modifier.height(6.dp))
                Text(
                    text = "Join PalitOra and start your shopping journey",
                    fontSize = 14.sp,
                    color = Color.White.copy(alpha = 0.85f),
                    textAlign = TextAlign.Center
                )

                Spacer(Modifier.height(40.dp))

                // 🔹 White card for inputs
                Card(
                    modifier = Modifier
                        .fillMaxWidth()
                        .shadow(10.dp, RoundedCornerShape(24.dp)),
                    shape = RoundedCornerShape(24.dp),
                    colors = CardDefaults.cardColors(containerColor = Color.White)
                ) {
                    Column(
                        modifier = Modifier
                            .padding(horizontal = 24.dp, vertical = 32.dp),
                        horizontalAlignment = Alignment.CenterHorizontally
                    ) {
                        Text(
                            text = "Creating as Buyer",
                            fontWeight = FontWeight.Bold,
                            fontSize = 22.sp,
                            color = Color(0xFFff6a00)
                        )

                        Spacer(Modifier.height(24.dp))

                        BuyerUsernameTF(
                            buyerUsername = buyerUsername,
                            buyerUsernameChange = { buyerUsername = it },
                            label = "Username",
                            placeholder = "Enter your username"
                        )

                        Spacer(Modifier.height(16.dp))

                        BuyerEmailTF(
                            buyerEmail = buyerEmail,
                            buyerEmailChange = { buyerEmail = it },
                            label = "Email",
                            placeholder = "Enter your email"
                        )

                        Spacer(Modifier.height(16.dp))

                        var passwordVisible by remember { mutableStateOf(false) }
                        BuyerPassTF(
                            buyerPass = buyerPass,
                            buyerPassChange = { buyerPass = it },
                            passwordVisible = passwordVisible,
                            onVisibilityChange = { passwordVisible = it },
                            label = "Password",
                            placeholder = "Enter your password"
                        )

                        Spacer(Modifier.height(16.dp))

                        var confirmVisible by remember { mutableStateOf(false) }
                        BuyerConfirmpassTF(
                            buyerConfirmpass = buyerConfirmpass,
                            buyerConfirmpassChange = { buyerConfirmpass = it },
                            passwordVisible = confirmVisible,
                            onVisibilityChange = { confirmVisible = it },
                            label = "Confirm Password",
                            placeholder = "Re-enter your password"
                        )

                        Spacer(Modifier.height(24.dp))

                        SignInButton("Sign Up") {
                            // Validation: Check if any field is empty
                            if (buyerUsername.isBlank() || buyerEmail.isBlank() || buyerPass.isBlank() || buyerConfirmpass.isBlank()) {
                                Toast.makeText(context, "Please fill in all fields", Toast.LENGTH_SHORT).show()
                                return@SignInButton
                            }

                            if (buyerPass != buyerConfirmpass) {
                                Toast.makeText(context, "Passwords do not match", Toast.LENGTH_SHORT).show()
                                return@SignInButton
                            }

                            (context as ComponentActivity).lifecycleScope.launch {
                                try {
                                    val response = ApiClient.api.registerUser(
                                        buyerUsername,
                                        buyerEmail,
                                        buyerPass,
                                        buyerConfirmpass
                                    )

                                    val body = response.body()
                                    val message = body?.message ?: "Unknown error"

                                    when {
                                        message.contains("Username already used", ignoreCase = true) -> {
                                            showUsernameDialog = true
                                        }
                                        message.contains("Email already used", ignoreCase = true) -> {
                                            showEmailDialog = true
                                        }
                                        body?.status.equals("success", ignoreCase = true) -> {
                                            Toast.makeText(context, message, Toast.LENGTH_SHORT).show()
                                            navController.navigate("login")
                                        }
                                        else -> {
                                            // Catch-all for any other error returned by PHP
                                            Toast.makeText(context, message, Toast.LENGTH_SHORT).show()
                                        }
                                    }

                                } catch (e: Exception) {
                                    // Fallback if Retrofit/Gson fails
                                    Toast.makeText(context, "Failed: ${e.message}", Toast.LENGTH_SHORT).show()
                                }
                            }
                        }

                        Spacer(Modifier.height(20.dp))

                        Row(
                            horizontalArrangement = Arrangement.Center,
                            modifier = Modifier.fillMaxWidth()
                        ) {
                            Text("Already have an account?", color = Color.Gray)
                            Spacer(Modifier.width(5.dp))
                            Text(
                                "Sign In",
                                color = Color(0xFF1a55ff),
                                fontWeight = FontWeight.SemiBold,
                                modifier = Modifier.clickable {
                                    navController.navigate("login")
                                }
                            )
                        }
                    }
                }

//                Spacer(Modifier.height(32.dp))
//
//                //  Continue as section
//                Text(
//                    text = "or continue as",
//                    color = Color.White,
//                    fontWeight = FontWeight.SemiBold,
//                    fontSize = 14.sp
//                )
//                Spacer(Modifier.height(12.dp))
//
//                Row(horizontalArrangement = Arrangement.Center) {
//                    RoleButton(
//                        label = "Seller",
//                        textColor = 0xFF000000,
//                        color = 0xFFfff0e6,
//                        onClick = { navController.navigate("sellerLogIn") }
//                    )
//                    Spacer(Modifier.width(16.dp))
//                    RoleButton(
//                        label = "Rider",
//                        textColor = 0xFF000000,
//                        color = 0xFF1a75ff,
//                        onClick = { navController }
//                    )
//                }
            }
        }
    }
}
