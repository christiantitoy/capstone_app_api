@Composable
fun ErrorDialog(
    text: String,
    showDialog: Boolean,
    onDismiss: () -> Unit
) {
    if (showDialog) {
        AlertDialog(
            onDismissRequest = { onDismiss() },
            title = {
                Text(
                    text = "⚠\uFE0F Error",
                    fontSize = 22.sp,
                    fontWeight = FontWeight.Bold,
                    textAlign = TextAlign.Center
                ) },
            text = {
                Text(
                    text = text,
                    fontSize = 16.sp
                ) },
            confirmButton = {
                TextButton(
                    onClick = { onDismiss() }
                ) {
                    Text("OK",
                        color = Color(0xFF00b300)
                        )
                }
            },
            shape = RoundedCornerShape(10.dp),
            containerColor = Color(0xFFffffff)
        )
    }
}
