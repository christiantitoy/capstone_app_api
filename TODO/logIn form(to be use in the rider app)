@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun UserLogInForm(navController: NavController) {
    var buyerEmail by remember { mutableStateOf("") }
    var buyerPass by remember { mutableStateOf("") }
    var passwordVisible by remember { mutableStateOf(false) }

    val context = LocalContext.current

    // ✨ Modern background gradient
    val gradient = Brush.verticalGradient(
        listOf(
            Color(0xFFFF914D),
            Color(0xFFFF6A00)
        )
    )

    Scaffold(
        containerColor = Color.White
    ) { innerPadding ->
        Box(
            modifier = Modifier
                .fillMaxSize()
                .background(gradient)
                .padding(innerPadding),
            contentAlignment = Alignment.Center
        ) {
            Column(
                modifier = Modifier
                    .fillMaxSize()
                    .verticalScroll(
                        rememberScrollState()
                    )
                    .padding(horizontal = 24.dp, vertical = 40.dp),
                horizontalAlignment = Alignment.CenterHorizontally
            ) {

                // 🔹 Header
                AppText(
                    text = "Welcome Back",
                    fontWeight = FontWeight.ExtraBold,
                    fontSize = 30.sp,
                    color = Color.White,
                    textAlign = TextAlign.Center
                )
                Spacer(Modifier.height(6.dp))
                Text(
                    text = "Sign in to continue shopping with PalitOra",
                    fontSize = 14.sp,
                    color = Color.White.copy(alpha = 0.85f),
                    textAlign = TextAlign.Center
                )
                Spacer(Modifier.height(40.dp))

                // 🔹 Card container for form
                Card(
                    modifier = Modifier
                        .fillMaxWidth()
                        .shadow(12.dp, RoundedCornerShape(24.dp)),
                    shape = RoundedCornerShape(24.dp),
                    colors = CardDefaults.cardColors(containerColor = Color.White)
                ) {
                    Column(
                        modifier = Modifier
                            .padding(horizontal = 24.dp, vertical = 32.dp),
                        horizontalAlignment = Alignment.CenterHorizontally
                    ) {
                        Text(
                            text = "Login as Buyer",
                            fontWeight = FontWeight.Bold,
                            fontSize = 22.sp,
                            color = Color(0xFFff6a00)
                        )

                        Spacer(Modifier.height(24.dp))

                        BuyerEmailTF(
                            buyerEmail = buyerEmail,
                            buyerEmailChange = { buyerEmail = it },
                            label = "Email",
                            placeholder = "Enter your email"
                        )

                        Spacer(Modifier.height(16.dp))

                        BuyerPassTF(
                            buyerPass = buyerPass,
                            buyerPassChange = { buyerPass = it },
                            passwordVisible = passwordVisible,
                            onVisibilityChange = { passwordVisible = it },
                            label = "Password",
                            placeholder = "Enter your password"
                        )

                        Spacer(Modifier.height(8.dp))
                        Text(
                            text = "Forgot Password?",
                            modifier = Modifier
                                .align(Alignment.End)
                                .clickable(
                                    indication = null,
                                    interactionSource = remember { MutableInteractionSource() }
                                ) {
                                    Toast
                                        .makeText(context, "Forgot password clicked", Toast.LENGTH_SHORT)
                                        .show()
                                },
                            color = Color(0xFFff6a00),
                            fontWeight = FontWeight.Medium,
                            fontSize = 14.sp
                        )

                        Spacer(Modifier.height(24.dp))

                        SignInButton("Sign In") {
                            (context as ComponentActivity).lifecycleScope.launch {
                                try {
                                    val response = ApiClient.api.loginUser(buyerEmail, buyerPass)
                                    if (response.isSuccessful) {
                                        val body = response.body()
                                        if (body?.status == "success") {
                                            Toast.makeText(context, "Welcome back!", Toast.LENGTH_SHORT).show()

                                            val sharedPref =
                                                context.getSharedPreferences("UserSession", Context.MODE_PRIVATE)
                                            with(sharedPref.edit()) {
                                                putInt("user_id", body.id ?: -1)
                                                putString("username", body.username ?: "")
                                                putString("email", body.email ?: "")
                                                val avatarUrl = if (!body.avatar_url.isNullOrEmpty()) {
                                                    if (body.avatar_url.startsWith("http")) body.avatar_url
                                                    else "http://10.46.179.249/capstone_app_api/${body.avatar_url}"
                                                } else ""
                                                putString("avatar_url", avatarUrl)
                                                apply()
                                            }
                                            navController.navigate("home") {
                                                popUpTo("login") { inclusive = true }
                                            }

                                        } else {
                                            Toast.makeText(context, body?.message ?: "Login failed", Toast.LENGTH_SHORT)
                                                .show()
                                        }
                                    } else {
                                        Toast.makeText(context, "Error: ${response.code()}", Toast.LENGTH_SHORT).show()
                                    }
                                } catch (e: Exception) {
                                    Toast.makeText(context, "Failed: ${e.message}", Toast.LENGTH_SHORT).show()
                                }
                            }
                        }

                        Spacer(Modifier.height(20.dp))

                        Row(
                            horizontalArrangement = Arrangement.Center,
                            modifier = Modifier.fillMaxWidth()
                        ) {
                            Text("Don’t have an account?", color = Color.Gray)
                            Spacer(Modifier.width(5.dp))
                            Text(
                                "Sign Up",
                                color = Color(0xFF1a55ff),
                                fontWeight = FontWeight.SemiBold,
                                modifier = Modifier.clickable {
                                    navController.navigate("createAcc")
                                }
                            )
                        }
                    }
                }

//                Spacer(Modifier.height(32.dp))
//
//                // 🔹 Continue as section
//                Text(
//                    text = "or continue as",
//                    color = Color.White,
//                    fontWeight = FontWeight.SemiBold,
//                    fontSize = 14.sp
//                )
//                Spacer(Modifier.height(12.dp))
//
//                Row(horizontalArrangement = Arrangement.Center) {
//                    RoleButton(
//                        label = "Seller",
//                        textColor = 0xFF000000,
//                        color = 0xFFfff0e6,
//                        onClick = { navController.navigate("sellerLogIn") }
//                    )
//                    Spacer(Modifier.width(16.dp))
//                    RoleButton(
//                        label = "Rider",
//                        textColor = 0xFFffffff,
//                        color = 0xFF1a75ff,
//                        onClick = { navController }
//                    )
//                }
            }
        }
    }
}

