@Composable
fun AppNavigation(
    purchaseViewModel: PurchaseViewModel
) {
    val context: Context = LocalContext.current

    val navController = rememberNavController()
    StartApp(navController)

    SlideTransitionNavHost(
        purchaseViewModel = purchaseViewModel,
        navController = navController
    )
}

