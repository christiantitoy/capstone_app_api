interface ApiSellerService {

    @GET("fetch_product.php")
    suspend fun fetchSellerProducts(
        @Query("seller_id") sellerId: Int
    ): Response<SellerProductsResponse>
//---------------------------------------------------------------------------------------------

    // ✅ Seller Registration
    @FormUrlEncoded
    @POST("register_seller.php")
    suspend fun registerSeller(
        @Field("buyer_id") buyerId: Int,
        @Field("fullname") fullname: String,
        @Field("shop_name") shopName: String,
        @Field("shop_description") shopDescription: String,
        @Field("phone_number") phoneNumber: String,
        @Field("business_address") businessAddress: String,
        @Field("business_type") businessType: String,
        @Field("shop_category") shopCategory: String
    ): Response<ApiSellerResponse>

    // ✅ Check if Seller Profile exists
    @FormUrlEncoded
    @POST("check_seller_profile.php")
    suspend fun checkSellerProfile(
        @Field("buyer_id") buyerId: Int
    ): Response<ApiSellerResponse>

//    -----------------------------------------------------------------------------------------------------

    // ✅ Seller Document Upload (FIXED)
    @Multipart
    @POST("seller_upload_documents.php")
    suspend fun uploadSellerDocuments(
        @Part buyerId: MultipartBody.Part,
        @Part businessIdType: MultipartBody.Part,
        @Part vararg documents: MultipartBody.Part  // CHANGED TO VARARGS
    ): Response<ApiDocumentUploadResponse>

//    -------------------------------------------------------------------------------------------------

    // ✅ Product APIs
    @GET("get_all_products.php")
    suspend fun getProducts(): Response<ProductsApiResponse>

    @GET("get_all_products.php")
    suspend fun getProductById(@Query("id") id: Int
    ): Response<ProductId>

    @GET("get_all_products_HasVariations.php")
    suspend fun getProductByIdHasVariations(@Query("id") id: Int
    ): Response<ProductHasVariations>

//    -----------------------------------------------------------------------------------------------------
//    MO ADD OG PRODUCTS NGA ENDPOINT API
    @POST("add_product.php")
    suspend fun addProductWithVariations(@Body request: AddProductRequest): Response<AddProductResponse>

//    ------------ KUHA SA PRICE AND STOCKS THE PRODUCTS WITH VARIANTS  ---------

    @GET("get_product_variant_by_options.php")
    suspend fun getVariantByOptions(
        @Query("product_id") productId: Int,
        @Query("options_value") optionsValue: String
    ): Response<VariantApiResponse>  // Changed to wrapper



    // ✅ Upload Image
    @Multipart
    @POST("upload_product_image.php")
    suspend fun uploadProductImage(
        @Part image: MultipartBody.Part
    ): Response<ApiImageResponse>

//    ---------------------------------------------------------------------------------------------------

//    FETCH NATO AND SELLER INFO
    @GET("fetch_sellers_info.php") // Replace with your PHP file path
    suspend fun getShopsInfo(): Response<ShopResponse>


    // CART API ENDPOINTS

    @POST("cart_add.php")
    suspend fun addToCart(@Body cartItem: CartItemRequest): Response<CartResponse>

    @GET("cart_get.php")
    suspend fun getCartItems(@Query("buyer_id") buyerId: Int): Response<CartListResponse>

    @PUT("cart_update.php")
    suspend fun updateCartItem(@Body updateRequest: UpdateCartRequest): Response<CartResponse>

    @HTTP(method = "DELETE", path = "cart_delete.php", hasBody = true)
    suspend fun removeCartItem(@Body removeRequest: RemoveCartRequest): Response<CartResponse>


    //    Address Endpoints

    @POST("update_address.php")
    suspend fun updateAddress(@Body addressData: UpdateAddressRequest): Response<AddressResponse>

    @HTTP(method = "DELETE", path = "delete_address.php", hasBody = true)
    suspend fun deleteAddress(@Body deleteData: DeleteAddressRequest): Response<AddressResponse>

    @POST("set_default_address.php")
    suspend fun setDefaultAddress(@Body setDefaultData: SetDefaultAddressRequest): Response<AddressResponse>

    @GET("get_addresses.php")
    suspend fun getAddresses(@Query("buyer_id") buyerId: Int): Response<AddressListResponse>

    @POST("save_address.php")
    suspend fun saveAddress(@Body addressData: AddressRequest): Response<AddressResponse>

    @GET("get_default_address.php")
    suspend fun getDefaultAddress(
        @Query("buyer_id") buyerId: Int
    ): Response<DefaultAddressResponse>


    @POST("place_order.php")
    suspend fun placeOrder(
        @Body request: PlaceOrderRequest
    ): Response<PlaceOrderResponse>

}


object ApiSeller {
    private const val BASE_URL = "http://10.138.231.249/capstone_app_api/"

    val api: ApiSellerService by lazy {
        Retrofit.Builder()
            .baseUrl(BASE_URL)
            .addConverterFactory(GsonConverterFactory.create())
            .build()
            .create(ApiSellerService::class.java)
    }
}